{% extends "base.jinja" %}
{% block title %}Political Data{% endblock %}

{% block content %}
<h1 class="fw-bold mb-1" style="font-size:1.75rem;">Jurisdictions</h1>
<p class="text-muted mb-4">Select a jurisdiction to explore its indicators.</p>

<div class="row g-3">
  {% for j in jurisdictions %}
  <div class="col-6 col-md-4 col-lg-3">
    <a href="{{ j.lower().replace(' ','_') }}.html" class="text-decoration-none">
      <div class="card h-100 p-3 text-center">
        <div class="fw-semibold" style="font-size:1.05rem;">{{ j }}</div>
      </div>
    </a>
  </div>
  {% endfor %}
</div>
{% endblock %}
