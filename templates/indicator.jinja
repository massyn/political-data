{% extends "base.jinja" %}
{% block title %}{{ ind.title }} — {{ jurisdiction }} — Political Data{% endblock %}

{% block extra_css %}
<style>
  .chart-wrap  { position: relative; height: 320px; }
  .bar-wrap    { position: relative; height: 220px; }
  .meta-pill   { display: inline-block; background: #e5e7eb; border-radius: 20px;
                 padding: .2rem .7rem; font-size: .78rem; margin-right: .35rem; color: #374151; }
  .data-table th { font-size: .8rem; font-weight: 600; color: #6b7280; white-space: nowrap; }
  .data-table td { font-size: .85rem; font-variant-numeric: tabular-nums; }
  .cell-good   { color: #15803d; font-weight: 600; }
  .cell-bad    { color: #b91c1c; font-weight: 600; }
</style>
{% endblock %}

{% block content %}
<nav aria-label="breadcrumb" class="mb-3">
  <ol class="breadcrumb">
    <li class="breadcrumb-item"><a href="index.html">Home</a></li>
    <li class="breadcrumb-item"><a href="{{ slug }}.html">{{ jurisdiction }}</a></li>
    <li class="breadcrumb-item active">{{ ind.title }}</li>
  </ol>
</nav>

<h1 class="fw-bold mb-2" style="font-size:1.6rem;">{{ ind.title }}</h1>

<div class="mb-3">
  <span class="meta-pill">{{ ind.category }}</span>
  <span class="meta-pill">{{ ind.frequency }}</span>
  <a class="meta-pill text-decoration-none" href="{{ ind._data.source }}" target="_blank" rel="noopener">Source &#8599;</a>
</div>

{% if ind._data.description %}
<p class="text-muted mb-4" style="font-size:.9rem; max-width:680px;">{{ ind._data.description }}</p>
{% endif %}

{% for graph in graphs %}

{# ── Time-series chart ── #}
<div class="card mb-3 p-3">
  <div class="fw-semibold mb-2">{{ graph.title }}</div>
  <div class="chart-wrap">
    <canvas id="chart-{{ loop.index0 }}"></canvas>
  </div>
</div>

{# ── Government performance bar chart ── #}
{% if graph.gov_perf %}
<div class="card mb-4 p-3">
  <div class="fw-semibold mb-1" style="font-size:.9rem;">
    Change per government term
    <span class="text-muted fw-normal" style="font-size:.78rem;">
      — green = improvement, red = worsening
    </span>
  </div>
  <div class="bar-wrap">
    <canvas id="bar-{{ loop.index0 }}"></canvas>
  </div>
</div>
{% endif %}

{% endfor %}

{# ── Data table ── #}
{% if table_rows %}
<div class="card p-3">
  <div class="fw-semibold mb-2">Data</div>
  <div style="max-height:360px; overflow-y:auto;">
    <table class="table table-sm table-hover data-table mb-0">
      <thead class="sticky-top bg-white">
        <tr>
          {% for h in table_headers %}<th>{{ h }}</th>{% endfor %}
        </tr>
      </thead>
      <tbody>
        {% for row in table_rows %}
        <tr>
          <td>{{ row[0] }}</td>
          {% for cell in row[1:] %}
          <td class="{% if cell.rag == 'good' %}cell-good{% elif cell.rag == 'bad' %}cell-bad{% endif %}">
            {{ cell.value }}
          </td>
          {% endfor %}
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
  <div class="text-muted mt-2" style="font-size:.78rem;">{{ table_rows | length }} records</div>
</div>
{% endif %}
{% endblock %}

{% block extra_js %}
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-adapter-date-fns@3.0.0/dist/chartjs-adapter-date-fns.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-annotation@3.0.1/dist/chartjs-plugin-annotation.min.js"></script>

<script>
const overlays = {{ overlays | tojson }};

function hexToRgba(hex, alpha) {
  const r = parseInt(hex.slice(1,3), 16);
  const g = parseInt(hex.slice(3,5), 16);
  const b = parseInt(hex.slice(5,7), 16);
  return `rgba(${r},${g},${b},${alpha})`;
}

function buildAnnotations(series, overlayList) {
  if (!overlayList || !overlayList.length || !series.length) return {};
  const firstDate = series[0].x;
  const lastDate  = series[series.length - 1].x;
  const annotations = {};
  overlayList.forEach((gov, i) => {
    const next   = overlayList[i + 1];
    if (next && next.date <= firstDate) return;
    if (gov.date > lastDate) return;
    const startD = gov.date > firstDate ? gov.date : firstDate;
    const endD   = next ? (next.date < lastDate ? next.date : lastDate) : lastDate;
    if (startD >= endD) return;
    const colour = gov.colour || '#cccccc';
    annotations[`box${i}`] = {
      type: 'box', xMin: startD, xMax: endD,
      backgroundColor: hexToRgba(colour, 0.15), borderWidth: 0, z: -1
    };
    if (gov.date > firstDate && gov.date <= lastDate) {
      annotations[`line${i}`] = {
        type: 'line', xMin: gov.date, xMax: gov.date,
        borderColor: 'rgba(0,0,0,0.3)', borderWidth: 1, borderDash: [4,4], z: 0,
        label: {
          display: true, content: gov.value.split(' ').pop(),
          position: 'start', yAdjust: -6,
          font: { size: 10 }, color: '#374151',
          backgroundColor: 'rgba(255,255,255,0.85)', padding: 3
        }
      };
    }
  });
  return annotations;
}

{% for graph in graphs %}
(function() {
  // ── time-series chart ──────────────────────────────────────────────────────
  const series     = {{ graph.series | tojson }};
  const overlayId  = {{ graph.overlay_id | tojson }};
  const overlayList = overlayId ? (overlays[overlayId] || []) : [];
  const annotations = buildAnnotations(series, overlayList);

  new Chart(document.getElementById('chart-{{ loop.index0 }}'), {
    type: 'line',
    data: {
      datasets: [{
        label: {{ graph.y_label | tojson }},
        data: series,
        borderColor: '#3b82f6',
        backgroundColor: 'rgba(59,130,246,0.07)',
        borderWidth: 2,
        pointRadius: series.length > 120 ? 0 : 2,
        tension: 0.1,
        fill: true
      }]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      interaction: { mode: 'index', intersect: false },
      plugins: {
        legend: { display: false },
        annotation: { annotations }
      },
      scales: {
        x: {
          type: 'time',
          time: { tooltipFormat: 'dd MMM yyyy', displayFormats: { month: 'MMM yy', year: 'yyyy' } },
          grid: { display: false },
          ticks: { maxTicksLimit: 10, font: { size: 11 } }
        },
        y: {
          title: { display: true, text: {{ graph.y_label | tojson }}, font: { size: 11 } },
          ticks: { font: { size: 11 } }
        }
      }
    }
  });

  {% if graph.gov_perf %}
  // ── government performance bar chart ──────────────────────────────────────
  const govPerf = {{ graph.gov_perf | tojson }};
  const labels  = govPerf.map(g => g.label);
  const deltas  = govPerf.map(g => g.delta);
  const fills   = govPerf.map(g =>
    g.rag === 'good'    ? 'rgba(21,128,61,0.75)' :
    g.rag === 'bad'     ? 'rgba(185,28,28,0.75)' :
                          'rgba(156,163,175,0.6)'
  );
  const borders = govPerf.map(g => g.colour || '#9ca3af');

  new Chart(document.getElementById('bar-{{ loop.index0 }}'), {
    type: 'bar',
    data: {
      labels,
      datasets: [{
        data: deltas,
        backgroundColor: fills,
        borderColor: borders,
        borderWidth: 2,
      }]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: {
        legend: { display: false },
        tooltip: {
          callbacks: {
            title: (items) => govPerf[items[0].dataIndex].full_name,
            label: (item) => {
              const g = govPerf[item.dataIndex];
              const sign = item.raw >= 0 ? '+' : '';
              return `${sign}${item.raw.toFixed(2)}  (${g.rag})`;
            }
          }
        }
      },
      scales: {
        x: { ticks: { font: { size: 11 } }, grid: { display: false } },
        y: {
          title: { display: true, text: {{ graph.y_label | tojson }}, font: { size: 11 } },
          ticks: { font: { size: 11 } },
          grid: {
            color: (ctx) => ctx.tick.value === 0 ? 'rgba(0,0,0,0.3)' : 'rgba(0,0,0,0.06)'
          }
        }
      }
    }
  });
  {% endif %}
})();
{% endfor %}
</script>
{% endblock %}
