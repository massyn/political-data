{% extends "base.jinja" %}
{% block title %}{{ jurisdiction }} — Political Data{% endblock %}

{% block extra_css %}
<style>
  .rag-dot { width: 9px; height: 9px; border-radius: 50%; display: inline-block; flex-shrink: 0; }
  .rag-good { background: #16a34a; }
  .rag-bad  { background: #dc2626; }
  .rag-none { background: #d1d5db; }
</style>
{% endblock %}

{% block content %}
<nav aria-label="breadcrumb" class="mb-3">
  <ol class="breadcrumb">
    <li class="breadcrumb-item"><a href="index.html">Home</a></li>
    <li class="breadcrumb-item active">{{ jurisdiction }}</li>
  </ol>
</nav>

<h1 class="fw-bold mb-4" style="font-size:1.75rem;">{{ jurisdiction }}</h1>

{% for category, rows in categories.items() %}
<div class="card mb-3">
  <div class="px-3 py-2 section-title">{{ category }}</div>
  {% for row in rows %}
  <a href="{{ row.url }}" class="metric-row">
    <span class="metric-name">{{ row.title }}</span>
    <span class="metric-spark">{{ row.sparkline | safe }}</span>
    <span style="display:flex;align-items:center;width:14px;flex-shrink:0;">
      <span class="rag-dot {% if row.rag == 'good' %}rag-good{% elif row.rag == 'bad' %}rag-bad{% else %}rag-none{% endif %}"></span>
    </span>
    <span class="metric-val">
      {% if row.latest_value is not none %}{{ row.latest_value }}{% endif %}
    </span>
    <span class="metric-date">{{ row.latest_date or '' }}</span>
  </a>
  {% endfor %}
</div>
{% endfor %}
{% endblock %}
